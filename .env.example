# Required for real submissions.
SPORTSPREDICT_API_KEY=replace_with_sportspredict_bot_key
OPENAI_API_KEY=replace_with_openai_key
XAI_API_KEY=replace_with_xai_key
ANTHROPIC_API_KEY=replace_with_anthropic_key

# Defaults are chosen for quality first without using GPT-5.5 Pro.
FORECAST_MODEL=gpt-5
RESEARCH_MODEL=gpt-5.4-mini
GROK_RESEARCH_MODEL=grok-4.20-multi-agent-0309
GROK_RESEARCH_PASSES=overview,late_news,market_micro
GROK_RESEARCH_REASONING_EFFORT=medium
GROK_FORECAST_MODELS=grok-4.3,grok-4.20-0309-reasoning
CLAUDE_FORECAST_MODELS=claude-opus-4-8,claude-opus-4-6
USE_OPENAI_FORECAST=true
USE_GROK_RESEARCH=true
USE_GROK_FORECAST=true
USE_CLAUDE_FORECAST=true
OPENAI_FORECAST_VARIANTS=base_rate_frequency
GROK_FORECAST_VARIANTS=base_rate_frequency
CLAUDE_FORECAST_VARIANTS=base_rate_frequency
OPENAI_FORECAST_WEIGHT=1.0
GROK_FORECAST_WEIGHT=0.35
CLAUDE_FORECAST_WEIGHT=1.0
REASONING_EFFORT=medium

# The bot dry-runs unless SUBMIT=true.
SUBMIT=false
SPORTSPREDICT_BASE_URL=https://api.sportspredict.com/api/v1
EVENT_TITLE=Probability Cup
RUN_INTERVAL_MINUTES=60
MAX_MATCHES_PER_RUN=0
MIN_HOURS_TO_CLOSE=0
MAX_HOURS_TO_CLOSE=168
ENABLE_UPDATE_GATE=true
MAX_PREDICTION_AGE_HOURS=12
FORCE_REFORECAST_WITHIN_HOURS=6
UPDATE_THRESHOLD_POINTS=2
EXTREMIZE_ALPHA=1.05
BASE_SHRINKAGE=0.04
LOW_EVIDENCE_SHRINKAGE=0.12
CONCURRENCY=4

# Optional: used to add market-implied sports context before LLM forecasting.
ODDS_API_KEY=
ODDS_SPORT_KEY=soccer
